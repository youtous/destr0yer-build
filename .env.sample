#!/usr/bin/env bash

# name of the cluster
CLUSTER_NAME=test-dev

# Environment — drives inventory path (inventories/$ENV/) and kluctl target (targets/$ENV.yaml)
ENV=dev

# where to save secrets and certs
SAVE_PATH=~/Nextcloud/linux/destr0yer-vault

EDITOR=vim

# SOPS age key for Kluctl secrets encryption (generated by: just sops-init)
SOPS_AGE_KEY_FILE=.dev/sops-age-key.txt

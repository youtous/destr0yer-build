#!/usr/bin/env bash
# {{ ansible_managed }}
# Check if public IP has changed and notify via email.
set -euo pipefail

STATE_FILE="{{ notify_change_ip_directory }}/host-ips.json"
EMAIL="{{ notify_change_ip_email }}"
HOSTNAME=$(hostname -f)

get_ipv4() {
  dig CH TXT whoami.cloudflare @1.1.1.1 +short -4 2>/dev/null | tr -d '"' || true
}

get_ipv6() {
  ip -6 addr show scope global 2>/dev/null | grep -oP '(?<=inet6 )\S+(?=/)' | head -1 || true
}

current_ipv4=$(get_ipv4)
current_ipv6=$(get_ipv6)

if [[ ! -f "$STATE_FILE" ]]; then
  printf '{"ipv4":"%s","ipv6":"%s"}\n' "$current_ipv4" "$current_ipv6" > "$STATE_FILE"
  echo "[$(date)] Initial state saved: ipv4=$current_ipv4 ipv6=$current_ipv6"
  exit 0
fi

old_ipv4=$(jq -r '.ipv4 // ""' "$STATE_FILE")
old_ipv6=$(jq -r '.ipv6 // ""' "$STATE_FILE")

changed=false

# Only consider a change if the new value is non-empty (avoid false alerts on DNS failure)
if [[ -n "$current_ipv4" && "$current_ipv4" != "$old_ipv4" ]]; then
  changed=true
fi
if [[ -n "$current_ipv6" && "$current_ipv6" != "$old_ipv6" ]]; then
  changed=true
fi

if [[ "$changed" == "true" ]]; then
  echo "[$(date)] IP change detected — notifying $EMAIL"
  mail -s "[$HOSTNAME] IP change detected" "$EMAIL" <<EOF
IPv4: $current_ipv4 (was: $old_ipv4)
IPv6: $current_ipv6 (was: $old_ipv6)
EOF
  printf '{"ipv4":"%s","ipv6":"%s"}\n' "$current_ipv4" "$current_ipv6" > "$STATE_FILE"
else
  echo "[$(date)] No change: ipv4=$current_ipv4 ipv6=$current_ipv6"
fi

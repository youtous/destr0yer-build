// {{ ansible_managed }}
// Automatically generated by Ansible — do not edit manually.

Unattended-Upgrade::Origins-Pattern {
{% for origin in unattended_upgrades_origins %}
    "{{ origin }}";
{% endfor %}
};

Unattended-Upgrade::Package-Blacklist {
{% for pkg in unattended_upgrades_package_blocklist %}
    "{{ pkg }}";
{% endfor %}
};

{% if unattended_upgrades_mail %}
Unattended-Upgrade::Mail "{{ unattended_upgrades_mail }}";
Unattended-Upgrade::MailReport "{{ 'on-error' if unattended_upgrades_mail_on_error_only else 'always' }}";
{% endif %}

Unattended-Upgrade::Remove-Unused-Kernel-Packages "{{ unattended_upgrades_remove_unused_kernel_packages | lower }}";
Unattended-Upgrade::Remove-Unused-Dependencies "{{ unattended_upgrades_remove_unused_dependencies | lower }}";

Unattended-Upgrade::Automatic-Reboot "{{ unattended_upgrades_automatic_reboot | lower }}";
Unattended-Upgrade::Automatic-Reboot-Time "{{ unattended_upgrades_automatic_reboot_time }}";

// Keep existing conffiles on upgrades — avoids interactive dpkg prompts
// that would silently skip security packages
Dpkg::Options {
    "--force-confold";
    "--force-confdef";
};

{% if unattended_upgrades_dl_limit > 0 %}
Acquire::http::Dl-Limit "{{ unattended_upgrades_dl_limit }}";
{% endif %}

{% if unattended_upgrades_syslog_enable %}
Unattended-Upgrade::SyslogEnable "true";
{% endif %}

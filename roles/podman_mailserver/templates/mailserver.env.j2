{{ ansible_managed | comment }}

OVERRIDE_HOSTNAME={{ podman_mailserver_hostname }}
LOG_LEVEL={{ podman_mailserver_log_level }}
POSTMASTER_ADDRESS={{ podman_mailserver_postmaster }}

# Rspamd
ENABLE_RSPAMD={{ podman_mailserver_enable_rspamd | ternary(1, 0) }}
ENABLE_RSPAMD_REDIS={{ podman_mailserver_enable_rspamd | ternary(1, 0) }}
RSPAMD_LEARN={{ podman_mailserver_enable_rspamd | ternary(1, 0) }}
RSPAMD_GREYLISTING=0
RSPAMD_HFILTER=1
RSPAMD_HFILTER_HOSTNAME_UNKNOWN_SCORE=6

# Legacy modules disabled (Rspamd handles everything)
ENABLE_OPENDKIM=0
ENABLE_OPENDMARC=0
ENABLE_POLICYD_SPF=0
ENABLE_SPAMASSASSIN=0
ENABLE_AMAVIS=0

# Security
ENABLE_FAIL2BAN={{ podman_mailserver_enable_fail2ban | ternary(1, 0) }}
ENABLE_CLAMAV={{ podman_mailserver_enable_clamav | ternary(1, 0) }}
SPOOF_PROTECTION=1
POSTSCREEN_ACTION=enforce

# TLS — manual cert, wildcard Let's Encrypt
SSL_TYPE=manual
SSL_CERT_PATH=/etc/dms/tls/fullchain.pem
SSL_KEY_PATH=/etc/dms/tls/privkey.pem
TLS_LEVEL={{ podman_mailserver_tls_level }}

# Protocols
ENABLE_IMAP=1
ENABLE_POP3=0
ENABLE_MANAGESIEVE=1

# Limits
POSTFIX_MAILBOX_SIZE_LIMIT={{ podman_mailserver_mailbox_size_limit }}
POSTFIX_MESSAGE_SIZE_LIMIT={{ podman_mailserver_message_size_limit }}

# Network
PERMIT_DOCKER=none

# Disabled features
ENABLE_FETCHMAIL=0
ENABLE_SRS=0
ENABLE_POSTGREY=0
ENABLE_QUOTAS=1

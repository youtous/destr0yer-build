{{ ansible_managed | comment }}
# Quadlet container — Nginx (MTA-STS + autodiscover/autoconfig reverse proxy)
# Rootless Podman, pasta networking via pod.

[Container]
ContainerName={{ podman_mailserver_nginx_container_name }}
# renovate: datasource=docker depName=nginx
Image={{ podman_mailserver_nginx_image }}:{{ podman_mailserver_nginx_version }}@{{ podman_mailserver_nginx_digest }}
Pod={{ podman_mailserver_pod_name }}.pod
ReadOnly=true

Volume={{ podman_mailserver_home }}/nginx/conf.d:/etc/nginx/conf.d:ro,Z
Volume={{ podman_mailserver_home }}/nginx/mta-sts:/etc/nginx/mta-sts:ro,Z
Volume={{ podman_mailserver_home }}/tls:/etc/nginx/tls:ro,Z
Tmpfs=/tmp
Tmpfs=/var/cache/nginx
Tmpfs=/var/run

HealthCmd=curl -so /dev/null -w '%{http_code}' http://127.0.0.1:80/ | grep -q 301
HealthInterval=30s
HealthRetries=3
HealthStartPeriod=10s
HealthTimeout=5s

[Service]
Restart=always
RestartSec=5

#!/bin/bash
{{ ansible_managed | comment }}

# Apply Debian security updates on every container start.
# Mitigates CVEs in DMS-bundled packages between version bumps.
apt-get update -qq && apt-get upgrade -y -qq --no-install-recommends \
  -o Dpkg::Options::="--force-confold" 2>&1 | tail -5

# Restrict TLS signature algorithms to SHA-256+ (exclude SHA-1, SHA-224).
# Postfix 3.7 has no native sigalgs parameter — must set via OpenSSL config.
# internet.nl / NCSC-NL §3.3.5: SHA-224 = "phase out", SHA-1/MD5 = "insufficient".
if ! grep -q '^SignatureAlgorithms' /etc/ssl/openssl.cnf; then
  if grep -q '\[system_default_sect\]' /etc/ssl/openssl.cnf; then
    sed -i '/\[system_default_sect\]/a SignatureAlgorithms = ECDSA+SHA256:ECDSA+SHA384:ECDSA+SHA512:RSA+SHA256:RSA+SHA384:RSA+SHA512:RSA-PSS+SHA256:RSA-PSS+SHA384:RSA-PSS+SHA512' /etc/ssl/openssl.cnf
  else
    cat >> /etc/ssl/openssl.cnf <<'EOF'

[openssl_init]
ssl_conf = ssl_sect

[ssl_sect]
system_default = system_default_sect

[system_default_sect]
SignatureAlgorithms = ECDSA+SHA256:ECDSA+SHA384:ECDSA+SHA512:RSA+SHA256:RSA+SHA384:RSA+SHA512:RSA-PSS+SHA256:RSA-PSS+SHA384:RSA-PSS+SHA512
EOF
  fi
fi

{{ ansible_managed | comment }}

# TLS hardening
smtp_tls_ciphers = high
smtpd_tls_ciphers = high
tls_preempt_cipherlist = yes
smtp_tls_mandatory_ciphers = high
smtpd_tls_mandatory_ciphers = high
smtpd_tls_security_level = may
smtp_tls_security_level = {{ podman_mailserver_smtp_tls_security_level | default('may') }}
tls_ssl_options = NO_COMPRESSION, NO_RENEGOTIATION
{% if podman_mailserver_dane_enabled | default(false) %}
smtp_dns_support_level = dnssec
{% endif %}

# Postscreen DNSBL
postscreen_dnsbl_sites = zen.spamhaus.org*3, bl.mailspike.net, b.barracudacentral.org*2, list.dnswl.org=127.0.[0..255].0*-2, list.dnswl.org=127.0.[0..255].1*-3, list.dnswl.org=127.0.[0..255].[2..3]*-4

# Access maps
smtpd_recipient_restrictions = permit_sasl_authenticated, permit_mynetworks, reject_unauth_destination, check_recipient_access texthash:/tmp/docker-mailserver/postfix-receive-access.cf
smtpd_sender_restrictions = permit_sasl_authenticated, permit_mynetworks, check_sender_access texthash:/tmp/docker-mailserver/postfix-send-access.cf

# Plus addressing (user+tag@domain → user@domain)
recipient_delimiter = +

# Virtual aliases — DMS default + regexp patterns (explicit)
virtual_alias_maps = texthash:/etc/postfix/virtual, pcre:/tmp/docker-mailserver/postfix-regexp.cf
# smtpd_sender_login_maps is NOT overridden here — DMS auto-loads postfix-regexp.cf
# into a unionmap that includes internal maps (sender_login_maps.pcre, aliases, virtual).
# Overriding it would break SPOOF_PROTECTION. The regexp patterns work for both
# receiving (virtual_alias_maps above) and sending (DMS unionmap) via the same file.

# {{ ansible_managed }}
[Unit]
Description=Send email on %i failure

[Service]
Type=oneshot
ExecStart=/bin/sh -c '\
  echo "Subject: [ALERT] %i failed on {{ ansible_hostname }}\nFrom: kopia@{{ ansible_hostname }}\nTo: {{ kopia_notification_email }}\n\nUnit %i failed at $(date -u).\n\nJournal (last 50 lines):\n$(journalctl -u %i --no-pager -n 50)" \
  | /usr/sbin/sendmail -t -f "kopia@{{ ansible_hostname }}"'

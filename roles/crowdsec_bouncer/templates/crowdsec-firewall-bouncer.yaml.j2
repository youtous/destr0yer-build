mode: {{ crowdsec_bouncer_backend }}
update_frequency: {{ crowdsec_bouncer_update_frequency }}
log_mode: file
log_dir: /var/log/
log_level: {{ crowdsec_bouncer_log_level }}
log_compression: true
log_max_size: 100
log_max_backups: 3
log_max_age: 30
api_url: http://{{ crowdsec_bouncer_lapi_host }}:{{ crowdsec_bouncer_lapi_port }}/
api_key: {{ crowdsec_bouncer_api_key }}
disable_ipv6: false
deny_action: REJECT
deny_log: true
deny_log_prefix: "crowdsec: "
supported_decisions_types:
  - ban
  - captcha
nftables:
  ipv4:
    enabled: true
    set-only: false
    table: crowdsec
    chain: crowdsec-chain
    priority: -10
  ipv6:
    enabled: true
    set-only: false
    table: crowdsec6
    chain: crowdsec6-chain
    priority: -10

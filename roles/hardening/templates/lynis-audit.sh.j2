#!/bin/sh
# {{ ansible_managed }}
set -eu

REPORT=$(mktemp)
trap 'rm -f "$REPORT"' EXIT

ESC=$(printf '\033')

# Pseudo-terminal forces Lynis to emit ANSI colors (isatty check)
script -qec "lynis audit system --quick --no-log --auditor systemd-timer" /dev/null 2>/dev/null \
  | tr -d '\r' > "$REPORT" || true

# Strip ANSI codes before parsing to avoid matching escape sequence digits
SCORE=$(sed "s/${ESC}\[[0-9;]*m//g" "$REPORT" | grep "Hardening index" | grep -oP "\d+" | head -1 || true)
WARNINGS=$(sed "s/${ESC}\[[0-9;]*m//g" "$REPORT" | grep -c "Warning:" || true)
SUGGESTIONS=$(sed "s/${ESC}\[[0-9;]*m//g" "$REPORT" | grep -c "Suggestion:" || true)
SUMMARY="Score: ${SCORE:-N/A}/100 | Warnings: $WARNINGS | Suggestions: $SUGGESTIONS"
echo "$SUMMARY"

{
  printf "Subject: [lynis] %s - {{ ansible_hostname }} (%s)\r\n" "$SUMMARY" "$(date +%Y-%m-%d)"
  printf "From: lynis@{{ ansible_hostname }}\r\n"
  printf "To: {{ lynis_notification_email }}\r\n"
  printf "MIME-Version: 1.0\r\n"
  printf "Content-Type: text/html; charset=utf-8\r\n"
  printf "\r\n"
  printf '<html><body><pre style="font-family:monospace;font-size:13px;background:#1e1e1e;color:#d4d4d4;padding:16px;border-radius:8px;overflow-x:auto;">'
  aha -bn < "$REPORT"
  printf '</pre></body></html>'
} | /usr/sbin/sendmail -t -f "lynis@{{ ansible_hostname }}"

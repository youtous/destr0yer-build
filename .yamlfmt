formatter:
  type: basic
  indent: 2
  include_document_end: false
  retain_line_breaks_single: true
  max_line_length: 0
  drop_merge_tag: false
  pad_line_comments: 2
  trim_trailing_whitespace: true
  eof_newline: true
extensions:
  - .yaml
  - .yml
exclude:
  - .helm-charts/
  - .ansible/
  - .cache/
  - archive/
  - roles/
  - kluctl/
  - "**/*.j2"
  - "**/*.j2.yaml"
  - "**/*.j2.yml"

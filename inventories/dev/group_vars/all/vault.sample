# vim: ts=2 sw=2 et
# Shared secrets for all hosts in the environment
# Location: inventories/<env>/group_vars/all/vault.yml
# Encrypt with: ansible-vault encrypt inventories/<env>/group_vars/all/vault.yml
# Edit with:    just vault-edit inventories/<env>/group_vars/all/vault.yml

# Name of the common sudo user (created on all hosts)
sudo_user_username: "walle"

# SSH public keys authorized for the sudo user (on all hosts)
# Include the dev key (.dev/id_ed25519.pub) for Vagrant environments
sudo_user_ssh_keys:
  - "ssh-ed25519 AAAA... destr0yer-dev"
  - "ssh-ed25519 AAAA... your-personal-key"

# Sudo password in cleartext (needed for ansible_become_pass delegation)
# Sudo user hashed password (generate with: openssl passwd -6)
sudo_user_password: ""
sudo_user_clear_password: ""

# SSH public keys authorized for the app deployer user (on ctrl nodes)
# Include the dev key (.dev/id_ed25519_deployer.pub) for Vagrant environments
deployer_ssh_keys:
  - "ssh-ed25519 AAAA... deployer-dev"

# CrowdSec bouncer API key — same value as SOPS secrets.crowdsec_bouncer_key
# Used by host-level nftables bouncer to connect to CrowdSec LAPI via NodePort
# Leave empty until LAPI is deployed (bouncer role is skipped when empty)
# Generate after deploy: just kubectl exec -n security deploy/crowdsec-lapi -- cscli bouncers add firewall-bouncer -o raw
crowdsec_bouncer_api_key: ""
